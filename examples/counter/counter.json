{
  "$schema": "../../packages/schema/schema.json",
  "$id": "Counter",

  "$defs": {
    "$count": {
      "type": "integer",
      "default": 0,
      "description": "Current counter value"
    },
    "$label": {
      "$prototype": "Function",
      "body": "const c = this.$count.get(); return c > 0 ? 'Clicked ' + c + ' time' + (c === 1 ? '' : 's') : 'Click me!';",
      "signal": true,
      "description": "Dynamic button label derived from $count"
    },
    "increment": {
      "$prototype": "Function",
      "body": "this.$count.set(this.$count.get() + 1);",
      "description": "Increase count by 1"
    },
    "decrement": {
      "$prototype": "Function",
      "body": "this.$count.set(Math.max(0, this.$count.get() - 1));",
      "description": "Decrease count by 1"
    },
    "reset": {
      "$prototype": "Function",
      "body": "this.$count.set(0);",
      "description": "Reset count to 0"
    }
  },

  "tagName": "my-counter",
  "style": {
    "display": "block",
    "fontFamily": "system-ui, sans-serif",
    "maxWidth": "300px",
    "margin": "2rem auto",
    "padding": "2rem",
    "textAlign": "center",
    "border": "1px solid #ddd",
    "borderRadius": "8px",
    "boxShadow": "0 2px 8px rgba(0,0,0,0.08)"
  },

  "children": [
    {
      "tagName": "h1",
      "textContent": { "$ref": "#/$defs/$label" },
      "style": {
        "fontSize": "1.5rem",
        "marginBottom": "0.5rem",
        "color": "#333"
      }
    },
    {
      "tagName": "p",
      "textContent": "${$count.get()}",
      "style": {
        "fontSize": "3rem",
        "fontWeight": "bold",
        "color": "#007bff",
        "margin": "1rem 0"
      }
    },
    {
      "tagName": "div",
      "style": {
        "display": "flex",
        "gap": "0.5rem",
        "justifyContent": "center"
      },
      "children": [
        {
          "tagName": "button",
          "textContent": "−",
          "onclick": { "$ref": "#/$defs/decrement" },
          "style": {
            "padding": "0.5rem 1.25rem",
            "fontSize": "1.25rem",
            "border": "1px solid #adb5bd",
            "borderRadius": "4px",
            "backgroundColor": "white",
            "cursor": "pointer",
            ":hover": { "backgroundColor": "#f8f9fa" }
          }
        },
        {
          "tagName": "button",
          "textContent": "+",
          "onclick": { "$ref": "#/$defs/increment" },
          "style": {
            "padding": "0.5rem 1.25rem",
            "fontSize": "1.25rem",
            "border": "none",
            "borderRadius": "4px",
            "backgroundColor": "#007bff",
            "color": "white",
            "cursor": "pointer",
            ":hover": { "backgroundColor": "#0056b3" }
          }
        },
        {
          "tagName": "button",
          "textContent": "Reset",
          "onclick": { "$ref": "#/$defs/reset" },
          "style": {
            "padding": "0.5rem 1rem",
            "fontSize": "0.9rem",
            "border": "1px solid #6c757d",
            "borderRadius": "4px",
            "backgroundColor": "white",
            "color": "#6c757d",
            "cursor": "pointer",
            ":hover": { "backgroundColor": "#f8f9fa" }
          }
        }
      ]
    }
  ]
}
