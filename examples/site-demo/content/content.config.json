{
  "collections": {
    "blog": {
      "source": "./blog/**/*.md",
      "schema": {
        "type": "object",
        "properties": {
          "title": { "type": "string" },
          "description": { "type": "string" },
          "pubDate": { "type": "string", "format": "date" },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          },
          "draft": { "type": "boolean", "default": false }
        },
        "required": ["title", "pubDate"]
      }
    }
  }
}
