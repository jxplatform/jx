{
  "$schema": "../../packages/schema/schema.json",
  "$id": "FetchDemo",

  "$defs": {
    "searchTerm":     { "type": "string",  "default": "" },
    "selectedUserId": { "type": "string",  "default": "" },
    "currentPage":    { "type": "integer", "default": 1 },
    "perPage":        { "type": "integer", "default": 10 },

    "allPosts": {
      "$prototype": "Request",
      "url": "https://jsonplaceholder.typicode.com/posts",
      "timing": "client",
      "signal": true,
      "description": "All posts — fetched once on mount"
    },
    "allUsers": {
      "$prototype": "Request",
      "url": "https://jsonplaceholder.typicode.com/users",
      "timing": "client",
      "signal": true,
      "description": "All users — fetched once, used for author names"
    },

    "userOptions": {
      "$prototype": "Function",
      "body": "const u = $defs.allUsers || []; return [{ id: '', name: 'All authors' }, ...u];",
      "signal": true,
      "description": "Options for the author filter select"
    },
    "filteredPosts": {
      "$prototype": "Function",
      "$src": "./fetch-demo.js",
      "signal": true,
      "description": "Posts filtered by searchTerm + selectedUserId"
    },
    "paginatedPosts": {
      "$prototype": "Function",
      "$src": "./fetch-demo.js",
      "signal": true,
      "description": "Current page slice of filteredPosts"
    },
    "totalPages": {
      "$prototype": "Function",
      "body": "const f = $defs.filteredPosts || []; return Math.max(1, Math.ceil(f.length / $defs.perPage));",
      "signal": true
    },
    "statsText": {
      "$prototype": "Function",
      "$src": "./fetch-demo.js",
      "signal": true
    },

    "onSearch": {
      "$prototype": "Function",
      "arguments": ["event"],
      "body": "$defs.searchTerm = event.target.value; $defs.currentPage = 1;"
    },
    "onUserFilter": {
      "$prototype": "Function",
      "arguments": ["event"],
      "body": "$defs.selectedUserId = event.target.value; $defs.currentPage = 1;"
    },
    "prevPage": {
      "$prototype": "Function",
      "body": "if ($defs.currentPage > 1) $defs.currentPage--;"
    },
    "nextPage": {
      "$prototype": "Function",
      "body": "if ($defs.currentPage < $defs.totalPages) $defs.currentPage++;"
    },
    "clearSearch": {
      "$prototype": "Function",
      "body": "$defs.searchTerm = ''; $defs.selectedUserId = ''; $defs.currentPage = 1;"
    }
  },

  "tagName": "div",
  "style": {
    "fontFamily": "system-ui, sans-serif",
    "background": "#f8f9fa",
    "minHeight": "100vh",
    "padding": "2em",
    "margin": "0",
    "boxSizing": "border-box"
  },

  "children": [
    {
      "tagName": "h2",
      "textContent": "Declarative Fetch",
      "style": { "margin": "0 0 0.25em", "color": "#333" }
    },
    {
      "tagName": "p",
      "textContent": "allPosts and allUsers are Request prototypes — they auto-fetch on mount. filteredPosts and paginatedPosts are computed signals that update reactively as you type or filter.",
      "style": { "color": "#6c757d", "margin": "0 0 1.5em", "fontSize": "0.9em", "maxWidth": "640px" }
    },

    {
      "tagName": "div",
      "style": {
        "maxWidth": "640px",
        "display": "flex",
        "gap": "0.5em",
        "marginBottom": "0.5em"
      },
      "children": [
        {
          "tagName": "input",
          "value": "${$defs.searchTerm}",
          "attributes": { "type": "text", "placeholder": "Search titles and content…" },
          "oninput": { "$ref": "#/$defs/onSearch" },
          "style": {
            "flex": "1",
            "padding": "0.5em 0.75em",
            "border": "1px solid #ced4da",
            "borderRadius": "4px",
            "fontSize": "0.9em",
            "outline": "none",
            ":focus": { "borderColor": "#007bff", "boxShadow": "0 0 0 2px rgba(0,123,255,0.15)" }
          }
        },
        {
          "tagName": "select",
          "value": "${$defs.selectedUserId}",
          "onchange": { "$ref": "#/$defs/onUserFilter" },
          "style": {
            "padding": "0.5em 0.5em",
            "border": "1px solid #ced4da",
            "borderRadius": "4px",
            "fontSize": "0.9em",
            "backgroundColor": "white",
            "cursor": "pointer"
          },
          "children": {
            "$prototype": "Array",
            "items": { "$ref": "#/$defs/userOptions" },
            "map": {
              "tagName": "option",
              "textContent": "${$map.item.name}",
              "attributes": { "value": "${$map.item.id}" }
            }
          }
        },
        {
          "tagName": "button",
          "textContent": "Clear",
          "onclick": { "$ref": "#/$defs/clearSearch" },
          "style": {
            "padding": "0.5em 0.9em",
            "border": "1px solid #ced4da",
            "borderRadius": "4px",
            "backgroundColor": "white",
            "cursor": "pointer",
            "fontSize": "0.9em",
            ":hover": { "backgroundColor": "#f8f9fa", "borderColor": "#adb5bd" }
          }
        }
      ]
    },

    {
      "tagName": "div",
      "textContent": { "$ref": "#/$defs/statsText" },
      "style": {
        "maxWidth": "640px",
        "fontSize": "0.8em",
        "color": "#6c757d",
        "marginBottom": "1em"
      }
    },

    {
      "tagName": "div",
      "style": { "maxWidth": "640px", "marginBottom": "1em" },
      "children": {
        "$prototype": "Array",
        "items": { "$ref": "#/$defs/paginatedPosts" },
        "map": {
          "tagName": "div",
          "style": {
            "backgroundColor": "white",
            "border": "1px solid #dee2e6",
            "borderRadius": "6px",
            "padding": "0.875em 1.125em",
            "marginBottom": "0.625em"
          },
          "children": [
            {
              "tagName": "div",
              "style": {
                "display": "flex",
                "justifyContent": "space-between",
                "alignItems": "baseline",
                "gap": "0.5em",
                "marginBottom": "0.4em"
              },
              "children": [
                {
                  "tagName": "h3",
                  "textContent": "${$map.item.title}",
                  "style": {
                    "margin": "0",
                    "fontSize": "0.9375em",
                    "color": "#212529",
                    "fontWeight": "600",
                    "textTransform": "capitalize"
                  }
                },
                {
                  "tagName": "span",
                  "textContent": "#${$map.item.id}",
                  "style": {
                    "fontSize": "0.75em",
                    "color": "#adb5bd",
                    "flexShrink": "0"
                  }
                }
              ]
            },
            {
              "tagName": "p",
              "textContent": "${($map.item.body||'').slice(0,120)}\u2026",
              "style": {
                "margin": "0 0 0.5em",
                "fontSize": "0.8375em",
                "color": "#6c757d",
                "lineHeight": "1.5"
              }
            },
            {
              "tagName": "span",
              "textContent": "${(($defs.allUsers||[]).find(u=>u.id===$map.item.userId)||{name:'User '+$map.item.userId}).name}",
              "style": {
                "fontSize": "0.775em",
                "color": "#007bff",
                "fontWeight": "500"
              }
            }
          ]
        }
      }
    },

    {
      "tagName": "div",
      "style": {
        "maxWidth": "640px",
        "display": "${$defs.totalPages > 1 ? 'flex' : 'none'}",
        "alignItems": "center",
        "justifyContent": "center",
        "gap": "0.75em"
      },
      "children": [
        {
          "tagName": "button",
          "textContent": "\u2190 Prev",
          "onclick": { "$ref": "#/$defs/prevPage" },
          "style": {
            "padding": "0.4em 0.9em",
            "border": "1px solid #ced4da",
            "borderRadius": "4px",
            "backgroundColor": "white",
            "fontSize": "0.875em",
            "opacity": "${$defs.currentPage <= 1 ? '0.4' : '1'}",
            "cursor": "${$defs.currentPage <= 1 ? 'default' : 'pointer'}"
          }
        },
        {
          "tagName": "span",
          "textContent": "Page ${$defs.currentPage} of ${$defs.totalPages}",
          "style": { "fontSize": "0.875em", "color": "#6c757d" }
        },
        {
          "tagName": "button",
          "textContent": "Next \u2192",
          "onclick": { "$ref": "#/$defs/nextPage" },
          "style": {
            "padding": "0.4em 0.9em",
            "border": "none",
            "borderRadius": "4px",
            "backgroundColor": "#007bff",
            "color": "white",
            "fontSize": "0.875em",
            "opacity": "${$defs.currentPage >= $defs.totalPages ? '0.4' : '1'}",
            "cursor": "${$defs.currentPage >= $defs.totalPages ? 'default' : 'pointer'}"
          }
        }
      ]
    }
  ]
}
