{
  "tagName": "div",
  "style": {
    "max-width": "640px",
    "margin": "0 auto"
  },
  "children": [
    {
      "tagName": "h1",
      "textContent": "Shoelace Components Demo"
    },
    {
      "tagName": "sl-card",
      "style": {
        "margin-bottom": "1rem"
      },
      "children": [
        {
          "tagName": "div",
          "attributes": {
            "slot": "header"
          },
          "children": [
            {
              "tagName": "strong",
              "textContent": "Welcome"
            }
          ]
        },
        {
          "tagName": "p",
          "textContent": "This page demonstrates Shoelace web components imported via $elements."
        },
        {
          "tagName": "div",
          "style": {
            "display": "flex",
            "gap": "0.5rem",
            "margin-top": "1rem"
          },
          "children": [
            {
              "tagName": "sl-button",
              "attributes": {
                "variant": "primary"
              },
              "textContent": "Primary"
            },
            {
              "tagName": "sl-button",
              "attributes": {
                "variant": "success"
              },
              "textContent": "Success"
            },
            {
              "tagName": "sl-button",
              "attributes": {
                "variant": "neutral",
                "outline": ""
              },
              "textContent": "Outline"
            }
          ]
        }
      ]
    },
    {
      "tagName": "sl-card",
      "style": {
        "margin-bottom": "1rem"
      },
      "children": [
        {
          "tagName": "div",
          "attributes": {
            "slot": "header"
          },
          "children": [
            {
              "tagName": "strong",
              "textContent": "Form Elements"
            }
          ]
        },
        {
          "tagName": "div",
          "style": {
            "display": "flex",
            "flex-direction": "column",
            "gap": "1rem"
          },
          "children": [
            {
              "tagName": "sl-input",
              "attributes": {
                "label": "Name",
                "placeholder": "Enter your name"
              }
            },
            {
              "tagName": "sl-textarea",
              "attributes": {
                "label": "Message",
                "placeholder": "Type a message…",
                "rows": "3"
              }
            },
            {
              "tagName": "sl-switch",
              "textContent": "Enable notifications"
            },
            {
              "tagName": "sl-button",
              "attributes": {
                "variant": "primary",
                "type": "submit"
              },
              "textContent": "Submit"
            }
          ]
        }
      ]
    },
    {
      "tagName": "sl-alert",
      "attributes": {
        "variant": "primary",
        "open": ""
      },
      "children": [
        {
          "tagName": "sl-icon",
          "attributes": {
            "slot": "icon",
            "name": "info-circle"
          }
        },
        {
          "tagName": "span",
          "textContent": "This is a Shoelace alert component rendered by the Jx runtime."
        }
      ]
    }
  ]
}
