{
  "$schema": "../../packages/schema/schema.json",
  "$id": "MarkdownBlog",

  "$defs": {
    "posts": {
      "$prototype": "MarkdownCollection",
      "$src": "../../packages/parser/md.js",
      "src": "./content/posts/*.md",
      "sortBy": "frontmatter.date",
      "sortOrder": "desc",
      "signal": true
    },
    "currentSlug": { "type": "string", "default": "getting-started" },
    "currentPost": {
      "$prototype": "MarkdownFile",
      "$src": "../../packages/parser/md.js",
      "src": "./content/posts/${$defs.currentSlug}.md",
      "signal": true
    },
    "selectPost": {
      "$prototype": "Function",
      "arguments": ["event"],
      "body": "event.preventDefault(); const slug = event.currentTarget.dataset?.slug; if (slug) $defs.currentSlug = slug;"
    }
  },

  "tagName": "markdown-blog",
  "style": {
    "fontFamily": "system-ui, -apple-system, sans-serif",
    "maxWidth": "960px",
    "margin": "2rem auto",
    "padding": "0 1rem",
    "display": "grid",
    "gridTemplateColumns": "300px 1fr",
    "gap": "2rem"
  },

  "children": [
    {
      "tagName": "aside",
      "style": { "borderRight": "1px solid #e0e0e0", "paddingRight": "1.5rem" },
      "children": [
        {
          "tagName": "h2",
          "textContent": "Posts",
          "style": { "marginTop": "0", "fontSize": "1.25rem" }
        },
        {
          "tagName": "ul",
          "style": { "listStyle": "none", "padding": "0", "margin": "0" },
          "children": {
            "$prototype": "Array",
            "items": { "$ref": "#/$defs/posts" },
            "map": {
              "tagName": "li",
              "style": { "marginBottom": "1rem" },
              "children": [
                {
                  "tagName": "a",
                  "style": {
                    "textDecoration": "none",
                    "color": "#0066cc",
                    "fontWeight": "600",
                    "cursor": "pointer",
                    ":hover": { "textDecoration": "underline" }
                  },
                  "textContent": "${$map.item?.frontmatter?.title ?? ''}",
                  "attributes": { "data-slug": "${$map.item?.slug ?? ''}" },
                  "onclick": { "$ref": "#/$defs/selectPost" }
                },
                {
                  "tagName": "time",
                  "style": { "display": "block", "fontSize": "0.8rem", "color": "#888" },
                  "textContent": "${$map.item?.frontmatter?.date ?? ''}"
                },
                {
                  "tagName": "span",
                  "style": { "fontSize": "0.75rem", "color": "#666" },
                  "textContent": "${($map.item?.$readingTime ?? '') + ' min read'}"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "tagName": "main",
      "children": [
        {
          "tagName": "header",
          "children": [
            {
              "tagName": "h1",
              "style": { "marginTop": "0" },
              "textContent": "${$defs.currentPost?.frontmatter?.title ?? 'Loading…'}"
            },
            {
              "tagName": "div",
              "style": { "color": "#666", "fontSize": "0.875rem", "marginBottom": "1.5rem" },
              "children": [
                {
                  "tagName": "time",
                  "textContent": "${$defs.currentPost?.frontmatter?.date ?? ''}"
                },
                { "tagName": "span", "textContent": " \u00b7 " },
                {
                  "tagName": "span",
                  "textContent": "${$defs.currentPost?.$readingTime ?? ''}"
                },
                { "tagName": "span", "textContent": " min read" }
              ]
            }
          ]
        },
        {
          "tagName": "article",
          "className": "prose",
          "innerHTML": "${$defs.currentPost?.$body ?? ''}"
        }
      ]
    }
  ]
}
