{
  "$schema": "https://declarative-dom.org/schema/v1",
  "$id": "ExamplesIndex",
  "$defs": {
    "$activeTab": { "type": "string", "default": "counter" },
    "$iframeSrc": { "type": "string", "default": "./counter/index.html" },
    "$sourceText": { "type": "string", "default": "Loading..." },
    "selectTab": {
      "$prototype": "Function",
      "$src": "./index.js",
      "description": "Switch active example tab"
    },
    "onMount": {
      "$prototype": "Function",
      "$src": "./index.js",
      "description": "Load initial source on mount"
    }
  },
  "tagName": "div",
  "style": {
    "fontFamily": "system-ui, sans-serif",
    "display": "flex",
    "flexDirection": "column",
    "height": "100vh",
    "margin": "0",
    "overflow": "hidden",
    "background": "#fff"
  },
  "children": [
    {
      "tagName": "nav",
      "style": {
        "display": "flex",
        "alignItems": "stretch",
        "borderBottom": "1px solid #e0e0e0",
        "background": "#f5f5f5",
        "padding": "0 0.5rem",
        "flexShrink": "0"
      },
      "children": {
        "$prototype": "Array",
        "items": [
          { "id": "counter",   "label": "Counter"   },
          { "id": "computed",  "label": "Computed"  },
          { "id": "list",      "label": "List"      },
          { "id": "fetch",     "label": "Fetch"     },
          { "id": "switch",    "label": "Switch"    },
          { "id": "form",      "label": "Form"      },
          { "id": "responsive","label": "Responsive"},
          { "id": "todo",      "label": "Todo"      }
        ],
        "map": {
          "tagName": "button",
          "textContent": "${$map.item.label}",
          "style": {
            "background": "none",
            "border": "none",
            "borderBottom": "2px solid transparent",
            "padding": "0.625rem 0.875rem",
            "cursor": "pointer",
            "fontSize": "0.8125rem",
            "fontWeight": "500",
            "color": "#555",
            "transition": "color 0.15s, border-color 0.15s",
            ":hover": {
              "color": "#111",
              "borderBottomColor": "#bbb"
            }
          },
          "attributes": { "data-tab": "${$map.item.id}" },
          "onclick": { "$ref": "#/$defs/selectTab" }
        }
      }
    },
    {
      "tagName": "div",
      "style": {
        "display": "flex",
        "flex": "1",
        "overflow": "hidden",
        "minHeight": "0"
      },
      "children": [
        {
          "tagName": "div",
          "style": {
            "flex": "1",
            "borderRight": "1px solid #e0e0e0",
            "overflow": "hidden",
            "display": "flex",
            "flexDirection": "column"
          },
          "children": [
            {
              "tagName": "div",
              "style": {
                "padding": "0.375rem 0.75rem",
                "fontSize": "0.6875rem",
                "fontWeight": "600",
                "textTransform": "uppercase",
                "letterSpacing": "0.05em",
                "color": "#999",
                "borderBottom": "1px solid #e0e0e0",
                "background": "#fafafa",
                "flexShrink": "0"
              },
              "textContent": "Preview"
            },
            {
              "tagName": "iframe",
              "src": { "$ref": "#/$defs/$iframeSrc" },
              "style": {
                "flex": "1",
                "border": "none",
                "width": "100%"
              }
            }
          ]
        },
        {
          "tagName": "div",
          "style": {
            "flex": "1",
            "overflow": "hidden",
            "display": "flex",
            "flexDirection": "column",
            "background": "#1e1e1e"
          },
          "children": [
            {
              "tagName": "div",
              "style": {
                "padding": "0.375rem 0.75rem",
                "fontSize": "0.6875rem",
                "fontWeight": "600",
                "textTransform": "uppercase",
                "letterSpacing": "0.05em",
                "color": "#888",
                "borderBottom": "1px solid #333",
                "background": "#252526",
                "flexShrink": "0"
              },
              "textContent": "Source"
            },
            {
              "tagName": "div",
              "style": {
                "flex": "1",
                "overflow": "auto"
              },
              "children": [
                {
                  "tagName": "pre",
                  "style": {
                    "margin": "0",
                    "padding": "1rem",
                    "fontSize": "0.75rem",
                    "lineHeight": "1.6",
                    "color": "#d4d4d4",
                    "fontFamily": "'Cascadia Code', 'Fira Code', 'Consolas', monospace",
                    "tabSize": "2"
                  },
                  "children": [
                    {
                      "tagName": "code",
                      "textContent": { "$ref": "#/$defs/$sourceText" }
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
