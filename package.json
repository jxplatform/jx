{
  "name": "jsonsx-workspace",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": ["packages/*", "examples"],
  "scripts": {
    "dev": "bun run examples/server.js",
    "build": "bun run --cwd packages/runtime build && bun run --cwd packages/studio build",
    "test": "bun test",
    "test:coverage": "bun test --coverage"
  }
}
